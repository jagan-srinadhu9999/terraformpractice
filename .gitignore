# Local .terraform directories
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*

# Crash log files
crash.log

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

#Ignore .tfvars files, which are likely to contain sensitive data, such as passwords or API keys. These should not be committed to version control.
*.tfvars

# CLI configuration files
.terraformrc
terraform.rc

# Dependency lock file (commit this if you want reproducible builds)
.terraform.lock.hcl

# Sensitive variable files (uncomment if you use them)
# terraform.tfvars
# *.auto.tfvars

